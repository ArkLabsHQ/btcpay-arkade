@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.ArkPayServer.Wallet
@model BTCPayServer.Plugins.ArkPayServer.Models.StoreOverviewViewModel
@inject IScopeProvider ScopeProvider
@inject ArkNetworkConfig ArkNetworkConfig

@{
    ViewData.SetActivePage(category: "Ark", activePage: "StoreOverview", title: "Ark - Overview");
    var storeId = ScopeProvider.GetCurrentStoreId();
}

<partial name="_StatusMessage" />

@if (Model.Balances != null)
{
    <partial name="_ArkBalances" model="Model.Balances" />
}

<div class="row g-3 mb-4">
    <!-- Wallet Card (Merged Status + Config) -->
    <div class="col-xl-8">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Wallet</h5>
                <partial name="_ServiceConnections" model="Model" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", true } }' />
            </div>
            <div class="card-body">
                <!-- Receive Address -->
                @if (!string.IsNullOrEmpty(Model.DefaultAddress) && Model.WalletType == WalletType.SingleKey)
                {
                    <div class="mb-3">
                        <label class="text-muted small">Receive Address</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control form-control-sm font-monospace" value="@Model.DefaultAddress" readonly data-testid="receive-address" />
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="copyAddress()" data-testid="copy-address-btn" title="Copy to clipboard">
                                <vc:icon symbol="copy" />
                            </button>
                        </div>
                    </div>
                }

                <div class="row g-3">
                    <!-- Left Column: Wallet Info -->
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Wallet Type</span>
                            <span class="badge @(Model.WalletType == WalletType.HD ? "text-bg-primary" : "text-bg-secondary")">
                                @(Model.WalletType == WalletType.HD ? "HD (BIP-39)" : "Legacy (nsec)")
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Wallet ID</span>
                            @if (!string.IsNullOrEmpty(Model.WalletId))
                            {
                                <vc:truncate-center text="@Model.WalletId" classes="truncate-center-id"/>
                            }
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Private Keys</span>
                            @if (Model.SignerAvailable)
                            {
                                <span class="badge text-bg-success">Available</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning">Watch-Only</span>
                            }
                        </div>
                    </div>

                    <!-- Right Column: Features -->
                    <div class="col-md-6">
                        @if (!string.IsNullOrEmpty(Model.BoltzUrl))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">Lightning</span>
                                <form asp-action="@(Model.IsLightningEnabled ? "DisableLightning" : "EnableLightning")" method="post" asp-route-storeId="@storeId" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(Model.IsLightningEnabled ? "btn-outline-secondary" : "btn-primary")">
                                        @(Model.IsLightningEnabled ? "Disable" : "Enable")
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">Lightning</span>
                                <span class="badge text-bg-secondary" title="Boltz service required">Unavailable</span>
                            </div>
                        }

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Auto-Sweep</span>
                            @if (!string.IsNullOrEmpty(Model.Destination))
                            {
                                <span class="badge text-bg-info">Enabled</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Disabled</span>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Sub-Dust</span>
                            @if (Model.AllowSubDustAmounts)
                            {
                                <span class="badge text-bg-info">Enabled</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Disabled</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Configuration Section -->
                <hr class="my-3" />

                <div class="row g-3">
                    <!-- Auto-Sweep Configuration -->
                    <div class="col-md-6">
                        <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId">
                            <label class="form-label text-muted small">Auto-Sweep Destination</label>
                            @if (Model.CanManagePrivateKeys)
                            {
                                @if (!string.IsNullOrEmpty(Model.Destination))
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <vc:truncate-center text="@Model.Destination" classes="truncate-center-id"/>
                                        <button type="submit" name="command" value="clear-destination" class="btn btn-sm btn-outline-danger">Clear</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="input-group input-group-sm">
                                        <input asp-for="Destination" class="form-control form-control-sm" placeholder="ark1..." />
                                        <button type="submit" name="command" value="save" class="btn btn-sm btn-primary">Save</button>
                                    </div>
                                }
                            }
                            else
                            {
                                @if (!string.IsNullOrEmpty(Model.Destination))
                                {
                                    <div><vc:truncate-center text="@Model.Destination" classes="truncate-center-id"/></div>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Not configured</span>
                                }
                            }
                        </form>
                    </div>

                    <!-- Sub-Dust Toggle -->
                    <div class="col-md-6">
                        <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId">
                            <label class="form-label text-muted small">Sub-Dust Amounts</label>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small text-muted">Accept payments below dust threshold</span>
                                <button type="submit" name="command" value="toggle-subdust"
                                        class="btn btn-sm @(Model.AllowSubDustAmounts ? "btn-outline-secondary" : "btn-outline-primary")"
                                        @(Model.IsDestinationSweepEnabled && !Model.AllowSubDustAmounts ? "disabled" : "")
                                        title="@(Model.IsDestinationSweepEnabled && !Model.AllowSubDustAmounts ? "Clear auto-sweep first" : "")">
                                    @(Model.AllowSubDustAmounts ? "Disable" : "Enable")
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Card -->
    <div class="col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    @if (Model.CanManagePrivateKeys)
                    {
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#transferModal" data-testid="send-btn">
                            <vc:icon symbol="actions-send" /> Transfer Funds
                        </button>
                    }
                    <form asp-action="SyncWallet" method="post" asp-route-storeId="@storeId">
                        <button type="submit" class="btn btn-outline-secondary w-100" data-testid="sync-wallet-btn">
                            <vc:icon symbol="actions-refresh" /> Sync Wallet
                        </button>
                    </form>
                    @if (Model.CanManagePrivateKeys)
                    {
                        <a asp-action="Send" asp-route-storeId="@storeId" asp-route-vtxos="all" class="btn btn-outline-secondary">
                            <vc:icon symbol="timer" /> Join Batch
                        </a>
                    }
                    @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet) && Model.CanManagePrivateKeys)
                    {
                        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#showPrivateKeyModal" data-testid="show-private-key-btn">
                            <vc:icon symbol="key" /> @(Model.WalletType == WalletType.HD ? "Show Seed" : "Show Key")
                        </button>
                    }
                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#clearWalletModal" data-testid="clear-wallet-btn">
                        <vc:icon symbol="cross" /> Clear Wallet
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Service Connections (Full Mode) -->
<partial name="_ServiceConnections" model="Model" />

<!-- Transfer Modal -->
<div class="modal fade" id="transferModal" tabindex="-1" aria-labelledby="transferModalLabel" aria-hidden="true" data-testid="transfer-modal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="transferModalLabel">Transfer Funds</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" data-testid="close-modal-btn"></button>
            </div>
            <form asp-action="Send" method="get" asp-route-storeId="@storeId">
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Destination</label>
                        <input type="text" name="destination" class="form-control"
                               placeholder="BIP21 URI, Lightning invoice, or Ark address..."
                               required data-testid="destination-input" />
                        <div class="form-text">
                            Enter a BIP21 URI, Lightning invoice (BOLT11), or Ark address to send funds to
                        </div>
                    </div>
                    @if (Model.Balances != null)
                    {
                        <div class="alert alert-info mb-0">
                            <strong>Available Balance:</strong> @Model.Balances.AvailableBalance sats
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <strong>Balance unavailable</strong> - indexer service may be down
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-testid="confirm-send-btn">Continue</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Show Private Key / Seed Phrase Modal -->
@if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet) && Model.CanManagePrivateKeys)
{
    <div class="modal fade" id="showPrivateKeyModal" tabindex="-1" aria-labelledby="showPrivateKeyModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="showPrivateKeyModalLabel">
                        @(Model.WalletType == WalletType.HD ? "Seed Phrase" : "Private Key")
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">
                        @if (Model.WalletType == WalletType.HD)
                        {
                            <text>Never share your seed phrase. Anyone with these words can spend your funds.</text>
                        }
                        else
                        {
                            <text>Never share your private key. Anyone with this key can spend your funds.</text>
                        }
                    </p>
                    <div class="input-group">
                        <input type="password" id="privateKeyInput" class="form-control font-monospace" value="@Model.Wallet" readonly />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePrivateKeyVisibility()">
                            <span id="eyeIcon">👁️</span>
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="copyPrivateKey()">
                            <vc:icon symbol="copy" />
                        </button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Clear Wallet Modal -->
<div class="modal fade" id="clearWalletModal" tabindex="-1" aria-labelledby="clearWalletModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clearWalletModalLabel">
                    <vc:icon symbol="warning" /> Clear Wallet Configuration
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ClearWallet" method="post" asp-route-storeId="@storeId">
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This will remove the Ark wallet configuration from this store.
                    </div>
                    <p class="mb-3">Are you sure you want to clear the wallet configuration? This action will:</p>
                    <ul>
                        <li>Remove the Ark payment method from this store</li>
                        <li>Disable Lightning if enabled via Arkade</li>
                        <li>Not delete any funds or VTXOs (they remain on the network)</li>
                    </ul>
                    @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet))
                    {
                        <div class="alert alert-info">
                            <strong>Important:</strong> Make sure you have backed up your private key before clearing. You can view it using the "Show Private Key" button.
                        </div>
                    }
                    <p class="text-muted mb-0">You can re-import the wallet later using the same private key or wallet ID.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Clear Wallet</button>
                </div>
            </form>
        </div>
    </div>
</div>


<script>
    function copyAddress() {
        const input = document.querySelector('input[data-testid="receive-address"]');
        if (input) {
            navigator.clipboard.writeText(input.value).then(() => {
                alert('Address copied to clipboard!');
            });
        }
    }

    function togglePrivateKeyVisibility() {
        const input = document.getElementById('privateKeyInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = '🙈';
        } else {
            input.type = 'password';
            icon.textContent = '👁️';
        }
    }

    function copyPrivateKey() {
        const input = document.getElementById('privateKeyInput');
        navigator.clipboard.writeText(input.value).then(() => {
            alert('Copied to clipboard!');
        });
    }
</script>
