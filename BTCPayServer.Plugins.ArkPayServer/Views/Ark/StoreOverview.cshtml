@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.ArkPayServer.Wallet
@model BTCPayServer.Plugins.ArkPayServer.Models.StoreOverviewViewModel
@inject IScopeProvider ScopeProvider

@{
    ViewData.SetActivePage(category: "Ark", activePage: "StoreOverview", title: "Arkade - Overview");
    var storeId = ScopeProvider.GetCurrentStoreId();
}

<partial name="_StatusMessage" />

<!-- Top Row: Wallet Info + Service Status -->
<div class="row g-4 mb-4">
    <!-- Wallet Info Tile -->
    <div class="col-xl-8">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                <h2 class="h5 mb-0">Wallet</h2>
                @if (Model.Balances != null)
                {
                    <partial name="_ArkBalances" model="Model.Balances" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", true }, { "NoContainer", true } }' />
                }
            </div>

            <!-- Receive Address -->
            @if (!string.IsNullOrEmpty(Model.DefaultAddress) && Model.WalletType == WalletType.SingleKey)
            {
                <div class="mb-3">
                    <label class="text-muted small">Receive Address</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control form-control-sm font-monospace" value="@Model.DefaultAddress" readonly data-testid="receive-address" />
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-clipboard="@Model.DefaultAddress" data-testid="copy-address-btn" title="Copy to clipboard">
                            <vc:icon symbol="copy" />
                        </button>
                    </div>
                </div>
            }

            <div class="row g-3">
                <!-- Left Column: Wallet Info -->
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Wallet Type</span>
                        <span class="badge @(Model.WalletType == WalletType.HD ? "text-bg-primary" : "text-bg-secondary")">
                            @(Model.WalletType == WalletType.HD ? "HD (BIP-39)" : "Legacy (nsec)")
                        </span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Wallet ID</span>
                        @if (!string.IsNullOrEmpty(Model.WalletId))
                        {
                            <vc:truncate-center text="@Model.WalletId" classes="truncate-center-id"/>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Private Keys</span>
                        @if (Model.SignerAvailable)
                        {
                            <span class="badge text-bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Watch-Only</span>
                        }
                    </div>
                </div>

                <!-- Right Column: Features -->
                <div class="col-md-6">
                    @if (!string.IsNullOrEmpty(Model.BoltzUrl))
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Lightning</span>
                            <form asp-action="@(Model.IsLightningEnabled ? "DisableLightning" : "EnableLightning")" method="post" asp-route-storeId="@storeId" class="d-inline">
                                <button type="submit" class="btn btn-sm  badge  text-primary @(Model.IsLightningEnabled ? "btn-outline-secondary" : "btn-outline-primary")">
                                    @(Model.IsLightningEnabled ? "Disable" : "Enable")
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Lightning</span>
                            <span class="badge text-bg-secondary" title="Boltz service required">Unavailable</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Auto-Sweep</span>
                        @if (Model.CanManagePrivateKeys)
                        {
                            <button type="button" class="btn btn-sm badge btn-outline-secondary text-primary"
                                    data-bs-toggle="modal" data-bs-target="#autoSweepModal"
                                    title="@(!string.IsNullOrEmpty(Model.Destination) ? Model.Destination : "Configure auto-sweep destination")">
                                @if (!string.IsNullOrEmpty(Model.Destination))
                                {
                                    <text>Enabled</text>
                                }
                                else
                                {
                                    <text>Configure</text>
                                }
                            </button>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(Model.Destination))
                            {
                                <span class="badge text-bg-info" title="@Model.Destination">Enabled</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Disabled</span>
                            }
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Sub-Dust</span>
                        <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId" class="d-inline">
                            <button type="submit" name="command" value="toggle-subdust"
                                    class="btn btn-sm badge text-primary btn-outline-secondary"
                                    @(Model.IsDestinationSweepEnabled && !Model.AllowSubDustAmounts ? "disabled" : "")
                                    title="@(Model.IsDestinationSweepEnabled && !Model.AllowSubDustAmounts ? "Clear auto-sweep first to disable" : "Accept payments below dust threshold")">
                                @(Model.AllowSubDustAmounts ? "Enabled" : "Disabled")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Service Status Tile -->
    <div class="col-xl-4">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <h2 class="h5 mb-3">Service Status</h2>
            <partial name="_ServiceConnections" model="Model" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", false } }' />
        </div>
    </div>
</div>

<!-- Bottom Row: VTXO List + Quick Actions -->
<div class="row g-4 mb-4">
    <!-- VTXO List Tile -->
    <div class="col-xl-8">
        <div class="bg-tile rounded p-3 p-sm-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Recent VTXOs</h2>
                <a asp-action="Vtxos" asp-route-storeId="@storeId" class="btn btn-sm btn-outline-secondary">
                    View All (@Model.TotalVtxoCount)
                </a>
            </div>

            <partial name="_VtxoTable" model="Model.RecentVtxos" view-data='new ViewDataDictionary(ViewData) {
                { "ShowAddressColumn", true },
                { "ShowSpendableStatus", true },
                { "CompactMode", true },
                { "VtxoContracts", Model.VtxoContracts },
                { "SpendableOutpoints", Model.SpendableOutpoints }
            }' />
        </div>
    </div>

    <!-- Quick Actions Tile -->
    <div class="col-xl-4">
        <div class="bg-tile rounded p-3 p-sm-4">
            <h2 class="h5 mb-3">Quick Actions</h2>
            <div class="d-grid gap-2">
                @if (Model.CanManagePrivateKeys)
                {
                    <a asp-action="Send2" asp-route-storeId="@storeId" class="btn btn-primary" data-testid="send-btn">
                        <vc:icon symbol="actions-send" /> Send
                    </a>
                    <a asp-action="Receive" asp-route-storeId="@storeId" class="btn btn-outline-primary" data-testid="receive-btn">
                        <vc:icon symbol="actions-receive" /> Receive
                    </a>
                }
                <form asp-action="SyncWallet" method="post" asp-route-storeId="@storeId">
                    <button type="submit" class="btn btn-outline-secondary w-100" data-testid="sync-wallet-btn">
                        <vc:icon symbol="actions-refresh" /> Sync Wallet
                    </button>
                </form>
                @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet) && Model.CanManagePrivateKeys)
                {
                    <a asp-controller="UIHome" asp-action="RecoverySeedBackup"
                       asp-route-ReturnUrl="@Url.Action("StoreOverview", "Ark", new { storeId })"
                       asp-route-IsStored="true"
                       asp-route-RequireConfirm="false"
                       asp-route-CryptoCode="ARK"
                       asp-route-Mnemonic="@Model.Wallet"
                       class="btn btn-outline-secondary" data-testid="show-private-key-btn">
                        <vc:icon symbol="key" /> @(Model.WalletType == WalletType.HD ? "Show Seed" : "Show Key")
                    </a>
                }
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#clearWalletModal" data-testid="clear-wallet-btn">
                    <vc:icon symbol="cross" /> Clear Wallet
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Auto-Sweep Configuration Modal -->
@if (Model.CanManagePrivateKeys)
{
    <div class="modal fade" id="autoSweepModal" tabindex="-1" aria-labelledby="autoSweepModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="autoSweepModalLabel">Auto-Sweep Configuration</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId">
                    <div class="modal-body">
                        <p class="text-muted small mb-3">
                            Auto-sweep automatically sends all received funds to a specified Arkade address.
                            This is useful for forwarding payments to another wallet.
                        </p>

                        @if (!string.IsNullOrEmpty(Model.Destination))
                        {
                            <div class="mb-3">
                                <label class="form-label">Current Destination</label>
                                <div class="input-group">
                                    <input type="text" class="form-control font-monospace" value="@Model.Destination" readonly />
                                </div>
                            </div>
                            <div class="alert alert-info small">
                                <strong>Auto-sweep is enabled.</strong> All received funds will be automatically forwarded to this address.
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="Destination" class="form-label">Destination Address</label>
                                <input asp-for="Destination" class="form-control font-monospace" placeholder="ark1..." />
                                <div class="form-text">Enter an Ark address to receive swept funds.</div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        @if (!string.IsNullOrEmpty(Model.Destination))
                        {
                            <button type="submit" name="command" value="clear-destination" class="btn btn-outline-danger">
                                Disable Auto-Sweep
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="command" value="save" class="btn btn-primary">
                                Enable Auto-Sweep
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Clear Wallet Modal -->
<div class="modal fade" id="clearWalletModal" tabindex="-1" aria-labelledby="clearWalletModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clearWalletModalLabel">
                    <vc:icon symbol="warning" /> Clear Wallet Configuration
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ClearWallet" method="post" asp-route-storeId="@storeId">
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This will remove the Arkade wallet configuration from this store.
                    </div>
                    <p class="mb-3">Are you sure you want to clear the wallet configuration? This action will:</p>
                    <ul>
                        <li>Remove the Arkade payment method from this store</li>
                        <li>Disable Lightning if enabled via Arkade</li>
                        <li>Not delete any funds or VTXOs (they remain on the network)</li>
                    </ul>
                    @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet))
                    {
                        <div class="alert alert-info">
                            <strong>Important:</strong> Make sure you have backed up your private key before clearing. You can view it using the "Show Private Key" button.
                        </div>
                    }
                    <p class="text-muted mb-0">You can re-import the wallet later using the same private key or wallet ID.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Clear Wallet</button>
                </div>
            </form>
        </div>
    </div>
</div>

