@using BTCPayServer.Plugins.ArkPayServer.Wallet
@model BTCPayServer.Plugins.ArkPayServer.Models.StoreOverviewViewModel

@if (!string.IsNullOrEmpty(Model.WalletId))
{
    <div class="widget store-wallet-balance" data-testid="ark-dashboard-widget">
        <header>
            <h3 text-translate="true">Arkade Wallet</h3>
            <a asp-controller="Ark" asp-action="StoreOverview" asp-route-storeId="@Model.StoreId" text-translate="true">View</a>
        </header>
        <div class="widget-body">
            <!-- Wallet Balances -->
            @if (Model.Balances != null)
            {
                <partial name="_ArkBalances" model="Model.Balances" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", true }, { "NoContainer", true } }' />
            }

            <!-- Receive Address -->
            @if (!string.IsNullOrEmpty(Model.DefaultAddress))
            {
                <div class="mt-3 pt-3 border-top">
                    <label class="text-muted small mb-1 d-block">Receive Address</label>
                    <div class="d-flex align-items-center gap-2">
                        <vc:truncate-center text="@Model.DefaultAddress" classes="truncate-center-id" />
                        <button type="button" class="btn btn-link btn-sm p-0" data-clipboard="@Model.DefaultAddress" title="Copy to clipboard">
                            <vc:icon symbol="copy" />
                        </button>
                    </div>
                </div>
            }

            <!-- Stats Row -->
            <div class="mt-3 pt-3 border-top d-flex align-items-center gap-4">
                <a asp-controller="Ark" asp-action="Vtxos" asp-route-storeId="@Model.StoreId" class="text-decoration-none">
                    <span class="fw-semibold">@Model.TotalVtxoCount</span>
                    <span class="text-muted small">VTXOs</span>
                </a>
                @if (Model.TotalIntentCount > 0)
                {
                    <a asp-controller="Ark" asp-action="Intents" asp-route-storeId="@Model.StoreId" class="text-decoration-none">
                        <span class="fw-semibold text-warning">@Model.TotalIntentCount</span>
                        <span class="text-muted small">pending</span>
                    </a>
                }
            </div>

            <!-- Service Status + Quick Actions -->
            <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                <partial name="_ServiceConnections" model="Model" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", true } }' />
                <div class="d-flex gap-2">
                    <a asp-controller="Ark" asp-action="Receive" asp-route-storeId="@Model.StoreId" class="btn btn-sm btn-outline-secondary">
                        Receive
                    </a>
                    <a asp-controller="Ark" asp-action="Send" asp-route-storeId="@Model.StoreId" class="btn btn-sm btn-primary">
                        Send
                    </a>
                </div>
            </div>
        </div>
    </div>
}
