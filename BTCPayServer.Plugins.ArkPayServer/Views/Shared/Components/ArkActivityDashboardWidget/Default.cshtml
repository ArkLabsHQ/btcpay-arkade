@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.ArkPayServer.Models
@model BTCPayServer.Plugins.ArkPayServer.Models.ArkActivityDashboardWidgetViewModel

<div class="widget store-numbers" data-testid="ark-activity-dashboard-widget">
    <header>
        <h6 text-translate="true">Arkade Activity</h6>
        <a asp-controller="Ark" asp-action="StoreOverview" asp-route-storeId="@Model.StoreId" text-translate="true">View</a>
    </header>
    @if (Model.Items.Any())
    {
        <div class="d-flex flex-column gap-3 mt-2 w-100" style="max-height:12rem;overflow-y:auto">
            @foreach (var item in Model.Items)
            {
                var typeLabel = item.Type switch
                {
                    ActivityItemType.Batch => "Batch",
                    ActivityItemType.Swap => "Swap",
                    ActivityItemType.Vtxo => "VTXO",
                    _ => ""
                };
                <div>
                    <div class="d-flex align-items-center justify-content-between">
                        <h6 class="mb-0">@typeLabel</h6>
                        <span class="badge @item.StatusClass">@item.StatusText</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between mt-1">
                        @if (!string.IsNullOrEmpty(item.Link))
                        {
                            <vc:truncate-center text="@item.Label" link="@item.Link" classes="truncate-center-id" />
                        }
                        else
                        {
                            <vc:truncate-center text="@item.Label" classes="truncate-center-id" />
                        }
                        <span class="text-muted small text-nowrap">@item.Date.ToTimeAgo()</span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-secondary mt-3 mb-0" text-translate="true">No recent activity.</p>
    }
</div>
