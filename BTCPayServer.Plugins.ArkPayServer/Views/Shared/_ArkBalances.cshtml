@model BTCPayServer.Plugins.ArkPayServer.Models.ArkBalancesViewModel

@{
    var compactMode = ViewData["CompactMode"] as bool? ?? false;
    var noContainer = ViewData["NoContainer"] as bool? ?? false;
    var totalBalance = (Model?.AvailableBalance ?? 0) + (Model?.RecoverableBalance ?? 0) + (Model?.UnspendableBalance ?? 0) + (Model?.LockedBalance ?? 0);
}

@if (Model != null)
{
    if (compactMode)
    {
        <!-- Compact Mode: Single line with all balances inline -->
        <div class="d-flex flex-wrap align-items-center gap-3" data-testid="wallet-balances-compact">
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small">Available:</span>
                <span class="fw-semibold text-primary" data-testid="wallet-balance">@Model.AvailableBalance sats</span>
            </div>
            @if (Model.RecoverableBalance > 0)
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">Recoverable:</span>
                    <span class="fw-semibold text-warning" data-testid="recoverable-balance">@Model.RecoverableBalance sats</span>
                </div>
            }
            @if (Model.UnspendableBalance > 0)
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">Unspendable:</span>
                    <span class="fw-semibold text-secondary" data-testid="unspendable-balance">@Model.UnspendableBalance sats</span>
                </div>
            }
            @if (Model.LockedBalance > 0)
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">Locked:</span>
                    <span class="fw-semibold text-info" data-testid="locked-balance">@Model.LockedBalance sats</span>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Full Mode: Row-based balance display -->
        if (!noContainer)
        {
            @:<div class="bg-tile rounded p-3 p-sm-4 mb-4" data-testid="wallet-balances">
        }
        else
        {
            @:<div data-testid="wallet-balances">
        }
            <!-- Balance Rows -->
            <div class="d-flex justify-content-between align-items-center py-2">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill bg-primary" style="width: 10px; height: 10px; padding: 0;"></span>
                    <span>Available</span>
                    <small class="text-muted">Ready to spend</small>
                </div>
                <span class="fw-semibold" data-testid="wallet-balance">@Model.AvailableBalance sats</span>
            </div>

            @if (Model.RecoverableBalance > 0)
            {
                <div class="d-flex justify-content-between align-items-center py-2 border-top">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge rounded-pill bg-warning" style="width: 10px; height: 10px; padding: 0;"></span>
                        <span>Recoverable</span>
                        <small class="text-muted">Needs batch recovery</small>
                    </div>
                    <span class="fw-semibold" data-testid="recoverable-balance">@Model.RecoverableBalance sats</span>
                </div>
            }

            @if (Model.UnspendableBalance > 0)
            {
                <div class="d-flex justify-content-between align-items-center py-2 border-top">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge rounded-pill bg-secondary" style="width: 10px; height: 10px; padding: 0;"></span>
                        <span>Unspendable</span>
                        <small class="text-muted">Waiting for conditions</small>
                    </div>
                    <span class="fw-semibold" data-testid="unspendable-balance">@Model.UnspendableBalance sats</span>
                </div>
            }

            @if (Model.LockedBalance > 0)
            {
                <div class="d-flex justify-content-between align-items-center py-2 border-top">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge rounded-pill bg-info" style="width: 10px; height: 10px; padding: 0;"></span>
                        <span>Locked</span>
                        <small class="text-muted">In pending intents</small>
                    </div>
                    <span class="fw-semibold" data-testid="locked-balance">@Model.LockedBalance sats</span>
                </div>
            }

            @if (totalBalance > Model.AvailableBalance)
            {
                <div class="d-flex justify-content-between align-items-center py-2 border-top mt-1">
                    <span class="fw-semibold">Total</span>
                    <span class="fw-bold">@totalBalance sats</span>
                </div>
                <!-- Progress bar showing balance composition -->
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar bg-primary" role="progressbar"
                         style="width: @((Model.AvailableBalance * 100m / totalBalance).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"
                         title="Available"></div>
                    @if (Model.RecoverableBalance > 0)
                    {
                        <div class="progress-bar bg-warning" role="progressbar"
                             style="width: @((Model.RecoverableBalance * 100m / totalBalance).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"
                             title="Recoverable"></div>
                    }
                    @if (Model.UnspendableBalance > 0)
                    {
                        <div class="progress-bar bg-secondary" role="progressbar"
                             style="width: @((Model.UnspendableBalance * 100m / totalBalance).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"
                             title="Unspendable"></div>
                    }
                    @if (Model.LockedBalance > 0)
                    {
                        <div class="progress-bar bg-info" role="progressbar"
                             style="width: @((Model.LockedBalance * 100m / totalBalance).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%"
                             title="Locked"></div>
                    }
                </div>
            }
        @:</div>
    }
}
